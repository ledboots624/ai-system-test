    <mxCell id="r3c3" value="「ロジックの制約定義」&#10;AIへの厳密な仕様指示書として機能し、&#10;ハルシネーションを抑制" style="rounded=0;whiteSpace=wrap;html=0;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=13;align=left;spacing=8;fontStyle=1" vertex="1" parent="1">
