    <mxCell id="r1c3" value="「データ多様性の確保」&#10;学習データのバイアス検知&#10;ツールとして機能" style="rounded=0;whiteSpace=wrap;html=0;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=13;align=left;spacing=8;fontStyle=1" vertex="1" parent="1">
