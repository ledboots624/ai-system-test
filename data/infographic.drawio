    <mxCell id="sec1_new" value="論理言語&#10;(AIへの指示)" style="ellipse;whiteSpace=wrap;html=0;aspect=fixed;fillColor=#1976D2;strokeColor=#0D47A1;fontColor=#ffffff;fontSize=14;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="340" y="210" width="120" height="120" as="geometry" />
    </mxCell>
    
    <mxCell id="sec1_desc" value="テスト技法（同値分割・境界値分析など）は、人間がテストケースを書くための「手順」から、AIに精密な仕様理解をさせるための「共通言語」へと進化しました。&#10;技法名を明示した構造化プロンプトが、生成品質を決定づけます。" style="text;html=0;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=14;fontColor=#37474F;" vertex="1" parent="1">
      <mxGeometry x="490" y="210" width="270" height="140" as="geometry" />
    </mxCell>

