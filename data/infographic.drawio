      <mxGeometry x="110" y="860" width="100" height="40" as="geometry" />
    </mxCell>
    
    <mxCell id="sec3_desc" value="AI支援開発では、統合テスト（Integration）の重要性が増します。&#10;&#10;◆ Unit: AIで量産可能だが、契約・依存関係の不整合は見逃しやすい。&#10;◆ Integration: モジュール間の接合部リスクを検証するため厚くする。&#10;◆ E2E: メンテナンスコスト削減のため「最小十分」に留める。" style="text;html=0;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontColor=#004D40;" vertex="1" parent="1">
