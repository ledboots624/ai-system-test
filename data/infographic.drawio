    <mxCell id="sec4_check_list" value="✅ CIパイプラインでの失敗テストゼロ化（フレイキー排除）&#10;✅ 外部依存に対する「契約テスト」のオールグリーン&#10;✅ 変異テスト（Mutation Testing）スコア 60%以上" style="text;html=0;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1;fontColor=#BF360C;lineHeight=1.6;" vertex="1" parent="1">
