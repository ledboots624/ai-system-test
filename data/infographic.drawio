    <!-- Concept Diagram: Manual to Logic -->
    <mxCell id="sec1_old" value="手順書&#10;(人間が書く)" style="ellipse;whiteSpace=wrap;html=0;aspect=fixed;fillColor=#B0BEC5;strokeColor=#78909C;fontColor=#ffffff;fontSize=14;fontStyle=1;" vertex="1" parent="1">
