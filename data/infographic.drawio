    <mxCell id="header_subtitle" value="上級エンジニア向け：古典的技法の再定義と実践的AI活用ノウハウ" style="text;html=0;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=16;fontColor=#E3F2FD;" vertex="1" parent="1">
