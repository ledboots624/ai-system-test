    <mxCell id="sec4_warn_text" value="コードとテストを同じAIセッションで&#10;生成すると、同じ誤りを共有し&#10;バグを見逃すリスクがある。" style="text;html=0;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=13;fontColor=#3E2723;" vertex="1" parent="1">
